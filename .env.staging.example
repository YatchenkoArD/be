# Конфиг staging-стека (docker-compose.staging.yml). Скопировать в .env.staging
# на сервере (chmod 600) и заполнить. НЕ переиспользовать боевые секреты прода:
# у staging свой SECRET_KEY, свой пароль БД и свои RS256-ключи в ./keys-staging
# (python -m app.scripts.gen_keys, затем перенести в keys-staging/).

# ENVIRONMENT задаётся в compose (production — staging ведёт себя как прод)

SECRET_KEY=CHANGE_ME_random_64_chars_staging_only

# БД staging — контейнер postgres из этого же стека (host/port ставит compose)
POSTGRES_USER=beauty_user
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password
POSTGRES_DB=beauty_platform

SQL_ECHO=false

# Хост staging для edge-Caddy и CORS. До домена — rumi-staging.test (пишется
# в /etc/hosts на машинах команды); с доменом — staging.<домен>
STAGING_DOMAIN=rumi-staging.test

# --- OTP ---
# Пока SMS-провайдер юридически не подключён: OTP выключен ЯВНО (guard в
# config.py не даст стартовать production-окружению без ACK).
# Когда появится аккаунт SMSC: OTP_ENABLED=true, SMS_MODE=live + креды ниже.
OTP_ENABLED=false
OTP_DISABLED_ACK=true
OTP_METHOD=flash_call
SMS_MODE=mock
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER_ID=
SMSRU_API_ID=
