# Конфиг staging-стека (docker-compose.staging.yml). Скопировать в .env.staging
# на сервере (chmod 600) и заполнить. НЕ переиспользовать боевые секреты прода:
# у staging свой SECRET_KEY, свой пароль БД и свои RS256-ключи в ./keys-staging
# (python -m app.scripts.gen_keys, затем перенести в keys-staging/).

# ENVIRONMENT задаётся в compose (production — staging ведёт себя как прод)

SECRET_KEY=CHANGE_ME_random_64_chars_staging_only

# БД staging — контейнер postgres из этого же стека (host/port ставит compose)
POSTGRES_USER=beauty_user
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password
POSTGRES_DB=beauty_platform

SQL_ECHO=false

# Хост staging для edge-Caddy и CORS. До домена — sslip.io (wildcard-DNS,
# имя публично резолвится в IP сервера: выдуманные хосты типа .test DPI
# провайдеров режет по SNI, а hosts-файл никому править не надо);
# с реальным доменом — staging.<домен>
STAGING_DOMAIN=staging.201-24-60-247.sslip.io

# --- OTP ---
# Пока SMS-провайдер юридически не подключён: OTP выключен ЯВНО (guard в
# config.py не даст стартовать production-окружению без ACK).
# Когда появится аккаунт SMSC: OTP_ENABLED=true, SMS_MODE=live + креды ниже.
OTP_ENABLED=false
OTP_DISABLED_ACK=true
OTP_METHOD=flash_call
SMS_MODE=mock
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER_ID=
SMSRU_API_ID=

# --- Подтверждение через Telegram-бота (блок 18) ---
# Живой канал подтверждения без СМС: с ним можно OTP_ENABLED=true даже при
# SMS_MODE=mock (guard пропустит; СМС-кнопка на странице не показывается).
# Токен — от @BotFather, username бота — без @.
TG_VERIFY_ENABLED=false
TG_BOT_TOKEN=
TG_BOT_USERNAME=
# Уведомления о записях через бота (клиенту, мастеру, бизнесу)
TG_NOTIFY_ENABLED=false

# --- Подтверждение через MAX-бота (блок 18, этап 2) ---
# Токен — из кабинета разработчика dev.max.ru, username бота — без @.
MAX_VERIFY_ENABLED=false
MAX_BOT_TOKEN=
MAX_BOT_USERNAME=

# --- Вход через Яндекс ID (OAuth, требует домена) ---
# Приложение: oauth.yandex.ru → Веб-сервисы, redirect:
#   https://rrumi.ru/api/v1/auth/yandex/callback (и staging-хост вторым URI)
# Доступы: login:default_phone (проверенный номер!), login:info
YANDEX_OAUTH_ENABLED=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Почта @rrumi.ru (SMTP Beget; MX/SPF в зоне Timeweb надо перевести на Beget) ---
# Ящики в панели Beget; mock = письма в лог (до правки MX/SPF в DNS!)
EMAIL_MODE=mock
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreply@rrumi.ru
SMTP_PASSWORD=
EMAIL_FROM=noreply@rrumi.ru
EMAIL_FROM_NAME=Руми

# --- Мониторинг и логи (блок 05) ---
# DSN из GlitchTip. Пусто = трекинг off. LOG_FORMAT=json уже задан в compose.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
