# Edge-Caddy: два хоста — прод и staging, оба через docker-сеть `edge`
# (см. docker-compose.edge.yml). До появления домена DOMAIN=localhost/IP →
# Caddy выдаёт самоподписанный сертификат (tls internal); с реальным доменом
# Let's Encrypt получается и продлевается автоматически.

# HTTP/3 выключен: QUIC — это UDP 443, а наружу опубликован (compose) и открыт
# в ufw только TCP. Анонсировать alt-svc h3 при закрытом UDP нельзя — браузер
# кэширует анонс, уходит в QUIC и виснет на загрузке. Чтобы включить h3:
# добавить "443:443/udp" в docker-compose.edge.yml, ufw allow 443/udp,
# убрать этот блок.
{
    servers {
        protocols h1 h2
    }
}

# ── Прод ─────────────────────────────────────────────────────────
{$DOMAIN:localhost} {
    # Пока DOMAIN = IP сервера, сертификат только самоподписанный: Let's Encrypt
    # не выдаёт сертификаты на IP (Caddy бесконечно ретраил ACME, хост оставался
    # без TLS вообще). С реальным доменом: PROD_TLS=<email> в .env → LE.
    tls {$PROD_TLS:internal}

    encode gzip
    reverse_proxy rumi-prod-app:8000

    # Доп. защита заголовками на уровне прокси (в приложении они тоже есть)
    header {
        -Server
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Content-Type-Options "nosniff"
    }
}

# ── Staging ──────────────────────────────────────────────────────
# Закрыт basic_auth: тестовый стенд не должен быть виден интернету
# (и поисковикам) без пароля. Дефолтные креды staging / rumi-staging-2026 —
# ВРЕМЕННЫЕ, при настройке сервера заменить хеш в .env (STAGING_BASIC_AUTH_HASH):
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'НОВЫЙ_ПАРОЛЬ'
{$STAGING_DOMAIN:rumi-staging.test} {
    # До реального домена — самоподписанный сертификат (по умолчанию internal).
    # С доменом: STAGING_TLS=<email> в .env → Caddy пойдёт в Let's Encrypt.
    tls {$STAGING_TLS:internal}

    encode gzip

    # Значения приходят из docker-compose.edge.yml (там же дефолты; Caddy-дефолт
    # в {$VAR:...} не сработал бы — compose передаёт переменную пустой строкой)
    basic_auth {
        {$STAGING_BASIC_AUTH_USER} {$STAGING_BASIC_AUTH_HASH}
    }

    reverse_proxy rumi-staging-app:8000

    header {
        -Server
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Content-Type-Options "nosniff"
        # staging не должен индексироваться, даже если basic_auth однажды снимут
        X-Robots-Tag "noindex, nofollow"
    }
}
