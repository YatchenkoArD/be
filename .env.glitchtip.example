# GlitchTip (блок 05) — заполнить и сохранить как .env.glitchtip (chmod 600, вне git).
# Запуск: docker compose -p rumi-glitchtip -f docker-compose.glitchtip.yml --env-file .env.glitchtip up -d

GLITCHTIP_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
GLITCHTIP_DB_PASSWORD=CHANGE_ME_strong_password
GLITCHTIP_DOMAIN=https://glitchtip.rrumi.ru

# Алерты на почту (SMTP Beget, как у приложения). Формат EMAIL_URL — dj-email-url:
#   submission (587/STARTTLS):  submission://USER:PASSWORD@smtp.beget.com:587
#   SMTPS (465/implicit TLS):   smtps://USER%40rrumi.ru:PASSWORD@smtp.beget.com:465
# ВНИМАНИЕ: '@' в логине кодировать как %40. До настройки — consolemail:// (в лог).
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=noreply@rrumi.ru
