# ── Скопируйте в .env и заполните реальными значениями. .env в .gitignore. ──

# Окружение
ENVIRONMENT=development

# Секрет для CSRF/HMAC. Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_generate_a_random_48_byte_secret

# JWT RS256. Сгенерируйте пару ключей: python -m app.scripts.gen_keys
# (по умолчанию пишутся в ./keys/, эти пути можно переопределить)
# JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookie: в проде ОБЯЗАТЕЛЬНО true (только по HTTPS)
COOKIE_SECURE=false

# CORS: список разрешённых origin через запятую (JSON-массив тоже подходит)
CORS_ORIGINS=["http://localhost:8000"]

# Redis для rate limiting и блокировки по аккаунту
REDIS_URL=redis://localhost:6379/0

# База данных. Локально — свой Postgres (localhost). В проде — управляемая
# PostgreSQL Timeweb: POSTGRES_HOST/PORT берутся из панели Timeweb.
# Компоуз-файл docker-compose.prod.yml больше не поднимает свой контейнер db.
POSTGRES_USER=beauty_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beauty_platform

# SQL-эхо в логи — в проде держать false
SQL_ECHO=false

# OTP (подтверждение телефона при регистрации). Код и его состояние живут
# в Redis (TTL) — своей БД/сервиса не требуется.
OTP_METHOD=flash_call
OTP_LENGTH=4
OTP_TTL_MINUTES=5
MAX_VERIFY_ATTEMPTS=3

# Провайдер отправки: mock (код никуда не уходит, виден в логе и в dev_code
# ответа /send-code — так и работаем, пока не подключён SMSC.ru/SMS.ru) или live.
SMS_MODE=mock
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_SENDER_ID=
SMSRU_API_ID=

# ВРЕМЕННО: SMS-провайдер ещё официально не подключён. false — регистрация
# пропускает реальную отправку/проверку кода (любой код считается верным).
# Когда SMSC.ru/SMS.ru будет настроен — поставить true (или убрать строку).
OTP_ENABLED=false

# Страховка от «выключенный OTP дожил до релиза»: в ENVIRONMENT=production
# приложение с OTP_ENABLED=false НЕ СТАРТУЕТ, пока это состояние не подтверждено
# явно (OTP_DISABLED_ACK=true). В development флаг не нужен.
# OTP_DISABLED_ACK=true

# --- Подтверждение телефона через Telegram-бота (блок 18) ---
# Бесплатная альтернатива СМС: бот просит «Поделиться контактом».
# Токен выдаёт @BotFather; username — без @ (для deep link t.me/<username>).
# TG_VERIFY_ENABLED=true
# TG_BOT_TOKEN=123456:ABC...
# TG_BOT_USERNAME=rumi_verify_bot

# --- Подтверждение телефона через MAX-бота (блок 18, этап 2) ---
# Токен — из кабинета dev.max.ru; username — без @.
# MAX_VERIFY_ENABLED=true
# MAX_BOT_TOKEN=...
# MAX_BOT_USERNAME=rumi_bot

# --- Edge-Caddy (docker-compose.edge.yml): домены обоих стеков ---
# До появления домена: DOMAIN=localhost (или IP сервера) — самоподписанный TLS.
DOMAIN=localhost
# sslip.io резолвится публично в IP из имени — выдуманные хосты (.test) DPI
# провайдеров режет по SNI; подставить IP своего сервера (точки → дефисы)
STAGING_DOMAIN=staging.201-24-60-247.sslip.io
# basic_auth на staging-хост. Дефолт (staging / rumi-staging-2026) — ВРЕМЕННЫЙ,
# на сервере сгенерировать свой хеш:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'ПАРОЛЬ'
STAGING_BASIC_AUTH_USER=staging
# ВАЖНО: каждый $ в bcrypt-хеше удвоить ($$) — docker compose интерполирует
# $-последовательности в значениях из .env (иначе хеш молча покалечится)
STAGING_BASIC_AUTH_HASH=

# S3 (VK Cloud, подключается через панель Timeweb) — для backup_to_s3.sh.
# Эндпоинт и бакет показываются при создании хранилища в панели.
S3_ENDPOINT=https://hb.bizmrg.com
S3_BUCKET=CHANGE_ME_bucket_name
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# --- Вход через Яндекс ID (OAuth, требует домена) ---
# Приложение: oauth.yandex.ru → Веб-сервисы, redirect:
#   https://rrumi.ru/api/v1/auth/yandex/callback (и staging-хост вторым URI)
# Доступы: login:default_phone (проверенный номер!), login:info
YANDEX_OAUTH_ENABLED=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Почта @rrumi.ru (SMTP Beget; MX/SPF в зоне Timeweb надо перевести на Beget) ---
# Ящики в панели Beget; mock = письма в лог (до правки MX/SPF в DNS!)
EMAIL_MODE=mock
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreply@rrumi.ru
SMTP_PASSWORD=
EMAIL_FROM=noreply@rrumi.ru
EMAIL_FROM_NAME=Руми

# --- Мониторинг и логи (блок 05) ---
# DSN из GlitchTip (self-host, docker-compose.glitchtip.yml). Пусто = трекинг off.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# LOG_FORMAT=json ставится в compose для prod/staging; локально можно text.
LOG_FORMAT=text
LOG_LEVEL=INFO
